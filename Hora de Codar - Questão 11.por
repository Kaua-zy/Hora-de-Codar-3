programa {
  funcao inicio() {
inteiro n
inteiro tabuada
inteiro contador

leia(n)

tabuada = 1

enquanto (tabuada <= n)
{
   escreva("Tabuada do ", tabuada, "\n")

   contador = 1

   enquanto (contador <= 10)
   {
      escreva(tabuada, " x ", contador, " = ", tabuada * contador, "\n")
      contador = contador + 1
   }

   escreva("\n")

   tabuada = tabuada + 1
}










  }


  }

